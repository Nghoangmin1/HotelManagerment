@model IEnumerable<HotelManagement.Models.RoomType>
@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Đặt phòng trực tuyến - Grand Aura Hotel";
}

<!-- Custom styles for landing page content -->
<style>
    .hero-banner {
        background: linear-gradient(rgba(15, 23, 42, 0.6), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1571896349842-33c89424de2d?auto=format&fit=crop&w=1200&q=80') no-repeat center center;
        background-size: cover;
        padding: 100px 24px;
        color: #ffffff;
        text-align: center;
    }

    .hero-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 20px;
        line-height: 1.2;
    }

    .hero-subtitle {
        font-size: 1.15rem;
        color: #cbd5e1;
        margin-bottom: 40px;
        font-weight: 400;
    }

    /* Booking Search Panel */
    .search-panel {
        background-color: #ffffff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.1), 0 8px 10px -6px rgba(15, 23, 42, 0.1);
        color: var(--text-dark);
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        max-width: 1000px;
        margin: -50px auto 0 auto;
        border: 1px solid var(--border);
    }

    .search-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-align: left;
    }

    .search-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #64748b;
        letter-spacing: 0.5px;
    }

    .search-input {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-family: inherit;
        font-size: 0.9rem;
        color: var(--text-dark);
        background-color: #ffffff;
        outline: none;
        transition: border-color 0.15s ease;
    }

    .search-input:focus {
        border-color: var(--primary);
    }

    /* Section styling */
    .section-container {
        max-width: 1200px;
        margin: 80px auto 0 auto;
        padding: 0 24px;
        text-align: center;
    }

    .section-tag {
        color: var(--primary);
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        display: inline-block;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-dark);
        margin-bottom: 16px;
    }

    .section-desc {
        max-width: 600px;
        margin: 0 auto 48px auto;
        color: #64748b;
        font-size: 0.95rem;
    }

    /* Products/Rooms Grid */
    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
        text-align: left;
    }

    .room-card {
        background-color: #ffffff;
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .room-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.08), 0 10px 10px -5px rgba(15, 23, 42, 0.04);
    }

    .room-thumbnail {
        height: 220px;
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
    }

    .room-thumbnail i {
        font-size: 4rem;
        opacity: 0.35;
    }

    .room-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background-color: rgba(15, 23, 42, 0.75);
        color: #ffffff;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .room-details {
        padding: 24px;
    }

    .room-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 10px;
    }

    .room-price {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--primary);
        font-family: 'Outfit', sans-serif;
        margin-bottom: 16px;
    }

    .room-price span {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 400;
    }

    .room-description {
        font-size: 0.85rem;
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 20px;
        height: 75px;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }

    .room-features {
        display: flex;
        gap: 16px;
        border-top: 1px solid var(--border);
        padding-top: 16px;
        margin-bottom: 20px;
        font-size: 0.8rem;
        color: #64748b;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-full {
        width: 100%;
        justify-content: center;
    }

    /* Amenities Grid */
    .amenities-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 40px;
    }

    .amenity-card {
        background-color: #ffffff;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        box-shadow: var(--shadow);
    }

    .amenity-icon {
        width: 48px;
        height: 48px;
        background-color: rgba(37, 99, 235, 0.08);
        color: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin: 0 auto 16px auto;
    }

    .amenity-card h4 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--text-dark);
    }

    .amenity-card p {
        font-size: 0.8rem;
        color: #64748b;
        line-height: 1.5;
    }

    /* Booking Modal Overlay styling */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: all 0.2s ease;
        z-index: 2000;
    }

    .modal-overlay.show {
        opacity: 1;
        pointer-events: auto;
    }

    .modal-box {
        background-color: #ffffff;
        border-radius: 16px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transform: scale(0.95);
        transition: transform 0.2s ease;
    }

    .modal-overlay.show .modal-box {
        transform: scale(1);
    }

    .modal-header {
        background-color: var(--dark);
        color: #ffffff;
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-title {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .modal-close {
        background: none;
        border: none;
        color: #94a3b8;
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.15s ease;
    }

    .modal-close:hover {
        color: #ffffff;
    }

    .modal-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .modal-footer {
        padding: 16px 24px;
        background-color: var(--light);
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .form-input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-family: inherit;
        font-size: 0.9rem;
        outline: none;
    }

    .form-input:focus {
        border-color: var(--primary);
    }
</style>

<!-- Hero Section -->
<section class="hero-banner">
    <div class="hero-container">
        <h1 class="hero-title">Khách Sạn Grand Aura</h1>
        <p class="hero-subtitle">Tận hưởng kỳ nghỉ dưỡng xa hoa, đẳng cấp 5 sao giữa trung tâm với dịch vụ lưu trú hoàn hảo và không gian sang trọng.</p>
    </div>
</section>

<!-- Search Panel (E-commerce Style filter) -->
<section style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
    <div class="search-panel">
        <div class="search-field">
            <span class="search-label">Ngày nhận phòng</span>
            <input type="date" class="search-input" value="2026-06-14" />
        </div>
        <div class="search-field">
            <span class="search-label">Ngày trả phòng</span>
            <input type="date" class="search-input" value="2026-06-15" />
        </div>
        <div class="search-field">
            <span class="search-label">Số khách lưu trú</span>
            <select class="search-input">
                <option>1 người lớn</option>
                <option selected>2 người lớn</option>
                <option>3 người lớn</option>
                <option>4 người lớn (Gia đình)</option>
            </select>
        </div>
        <div class="search-field" style="justify-content: flex-end;">
            <button class="btn btn-primary" style="justify-content: center; height: 46px; font-size: 0.95rem;" onclick="alert('Hệ thống đang tìm kiếm các phòng trống phù hợp cho bạn...')">
                <i class="fa-solid fa-magnifying-glass"></i> Tìm phòng trống
            </button>
        </div>
    </div>
</section>

<!-- Room Products List -->
<section class="section-container" id="room-listings">
    <span class="section-tag">Khám phá</span>
    <h2 class="section-title">Hệ Thống Phòng Nghỉ Cao Cấp</h2>
    <p class="section-desc">Grand Aura Hotel cung cấp đa dạng các sự lựa chọn phòng nghỉ từ phòng đơn Standard tinh tế cho đến các phòng Suite VIP thượng lưu.</p>

    <div class="rooms-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                string iconClass = "fa-bed";
                string gradient = "linear-gradient(135deg, #60a5fa 0%, #2563eb 100%)";
                string capacities = "1 Giường đơn";
                
                if (item.TypeName.Contains("Đôi"))
                {
                    iconClass = "fa-hotel";
                    gradient = "linear-gradient(135deg, #38bdf8 0%, #0369a1 100%)";
                    capacities = "1 Giường đôi / 2 Giường đơn";
                }
                else if (item.TypeName.Contains("Deluxe"))
                {
                    iconClass = "fa-award";
                    gradient = "linear-gradient(135deg, #818cf8 0%, #4f46e5 100%)";
                    capacities = "1 Giường đôi cỡ King";
                }
                else if (item.TypeName.Contains("VIP") || item.TypeName.Contains("Suite"))
                {
                    iconClass = "fa-crown";
                    gradient = "linear-gradient(135deg, #f59e0b 0%, #b45309 100%)";
                    capacities = "1 Giường đôi Super King";
                }

                <div class="room-card">
                    <div class="room-thumbnail" style="background: @gradient">
                        <i class="fa-solid @iconClass"></i>
                        <span class="room-badge">Hot</span>
                    </div>
                    <div class="room-details">
                        <h3 class="room-title">@item.TypeName</h3>
                        <p class="room-price">@item.BasePrice.ToString("N0")đ <span>/ đêm</span></p>
                        <p class="room-description">@item.Description</p>
                        
                        <div class="room-features">
                            <div class="feature-item">
                                <i class="fa-solid fa-bed"></i>
                                <span>@capacities</span>
                            </div>
                            <div class="feature-item">
                                <i class="fa-solid fa-wifi"></i>
                                <span>Wifi miễn phí</span>
                            </div>
                        </div>

                        <button class="btn btn-primary btn-full book-now-btn" 
                                data-room-type-id="@item.Id" 
                                data-room-type-name="@item.TypeName"
                                data-room-type-price="@item.BasePrice.ToString("N0")đ">
                            <i class="fa-solid fa-calendar-check"></i> Đặt phòng ngay
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1/-1; text-align: center; padding: 48px;">
                <i class="fa-solid fa-circle-exclamation" style="font-size: 3rem; color: var(--primary); margin-bottom: 16px;"></i>
                <p>Hệ thống phòng chưa được thiết lập. Vui lòng đăng nhập quyền quản trị để tạo cơ sở dữ liệu phòng mẫu.</p>
            </div>
        }
    </div>
</section>

<!-- Amenities Section -->
<section class="section-container" id="services" style="margin-bottom: 100px;">
    <span class="section-tag">Tiện ích</span>
    <h2 class="section-title">Dịch vụ chuẩn 5 sao</h2>
    <p class="section-desc">Chúng tôi mang lại những dịch vụ giải trí và chăm sóc sức khỏe tối tân giúp khách hàng có kỳ nghỉ đáng nhớ nhất.</p>

    <div class="amenities-grid">
        <div class="amenity-card">
            <div class="amenity-icon"><i class="fa-solid fa-water"></i></div>
            <h4>Bể bơi vô cực</h4>
            <p>Tọa lạc tại tầng thượng với view toàn cảnh thành phố thơ mộng, mở cửa phục vụ 6:00 - 22:00.</p>
        </div>
        <div class="amenity-card">
            <div class="amenity-icon"><i class="fa-solid fa-spa"></i></div>
            <h4>Spa & Massage</h4>
            <p>Trải nghiệm trị liệu thảo mộc truyền thống phục hồi năng lượng thể chất và tinh thần.</p>
        </div>
        <div class="amenity-card">
            <div class="amenity-icon"><i class="fa-solid fa-utensils"></i></div>
            <h4>Nhà hàng ẩm thực</h4>
            <p>Phục vụ buffet sáng miễn phí cùng các món ăn Á-Âu thượng hạng chuẩn đầu bếp Michelin.</p>
        </div>
        <div class="amenity-card">
            <div class="amenity-icon"><i class="fa-solid fa-clock"></i></div>
            <h4>Phục vụ 24/7</h4>
            <p>Dịch vụ giặt ủi, phục vụ thức ăn và hỗ trợ đặt xe/tour tham quan thành phố bất kể giờ giấc.</p>
        </div>
    </div>
</section>

<!-- Online Booking Modal Dialog -->
<div class="modal-overlay" id="online-booking-modal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-calendar-days"></i> Đăng ký đặt phòng trực tuyến</span>
            <button class="modal-close" id="online-modal-close-btn">&times;</button>
        </div>
        <form id="online-booking-form" onsubmit="handleOnlineBookingSubmit(event)">
            <div class="modal-body">
                <p style="font-size:0.85rem; color:var(--text-main); margin-bottom:8px; line-height:1.5;">
                    Bạn đang đăng ký giữ phòng: <strong id="modal-room-type-display" style="color:var(--primary);">Phòng đơn Standard</strong>. Chi phí dự kiến: <strong id="modal-room-price-display" style="color:var(--primary);">350.000đ/đêm</strong>.
                </p>
                
                <input type="hidden" id="modal-room-type-id-input" />

                <div class="form-field">
                    <label class="field-label">Họ và tên khách hàng</label>
                    <input type="text" id="cust-fullname" class="form-input" placeholder="Ví dụ: Nguyễn Văn A" required />
                </div>

                <div class="form-field">
                    <label class="field-label">Số điện thoại liên hệ</label>
                    <input type="tel" id="cust-phone" class="form-input" placeholder="Ví dụ: 0901234567" required />
                </div>

                <div class="form-field">
                    <label class="field-label">Số CMND / CCCD / Passport</label>
                    <input type="text" id="cust-idcard" class="form-input" placeholder="Nhập số giấy tờ cá nhân..." required />
                </div>

                <div class="form-field">
                    <label class="field-label">Địa chỉ email</label>
                    <input type="email" id="cust-email" class="form-input" placeholder="example@mail.com" required />
                </div>

                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:12px;">
                    <div class="form-field">
                        <label class="field-label">Ngày nhận phòng</label>
                        <input type="date" id="cust-checkin" class="form-input" value="2026-06-14" required />
                    </div>
                    <div class="form-field">
                        <label class="field-label">Ngày trả phòng</label>
                        <input type="date" id="cust-checkout" class="form-input" value="2026-06-15" required />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" id="online-modal-cancel-btn">Hủy bỏ</button>
                <button type="submit" class="btn btn-primary">Xác nhận giữ phòng</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const modal = document.getElementById('online-booking-modal');
        const closeBtn = document.getElementById('online-modal-close-btn');
        const cancelBtn = document.getElementById('online-modal-cancel-btn');
        const bookBtns = document.querySelectorAll('.book-now-btn');

        const roomTypeDisplay = document.getElementById('modal-room-type-display');
        const roomPriceDisplay = document.getElementById('modal-room-price-display');
        const roomTypeIdInput = document.getElementById('modal-room-type-id-input');

        bookBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                const typeId = this.getAttribute('data-room-type-id');
                const typeName = this.getAttribute('data-room-type-name');
                const typePrice = this.getAttribute('data-room-type-price');

                roomTypeIdInput.value = typeId;
                roomTypeDisplay.textContent = typeName;
                roomPriceDisplay.textContent = typePrice;

                modal.classList.add('show');
            });
        });

        function closeModal() {
            modal.classList.remove('show');
        }

        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
    });

    function handleOnlineBookingSubmit(event) {
        event.preventDefault();
        
        const name = document.getElementById('cust-fullname').value;
        const phone = document.getElementById('cust-phone').value;
        const roomName = document.getElementById('modal-room-type-display').textContent;

        alert(`Đăng ký giữ phòng thành công!\n\nKhách hàng: ${name}\nSố điện thoại: ${phone}\nLoại phòng: ${roomName}\n\nNhân viên khách sạn sẽ liên hệ để xác nhận đặt cọc trong vòng 10 phút. Cảm ơn quý khách!`);
        
        document.getElementById('online-booking-form').reset();
        document.getElementById('online-booking-modal').classList.remove('show');
    }
</script>
