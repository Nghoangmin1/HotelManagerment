@model IEnumerable<HotelManagement.Models.Room>
@{
    ViewData["Title"] = "Sơ đồ phòng khách sạn - Lễ tân";
}

<div class="glass-panel">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h1 class="section-title"><i class="fa-solid fa-hotel"></i> Sơ đồ phòng khách sạn</h1>
            <p class="section-desc">Theo dõi trạng thái phòng nghỉ và thực hiện nhận/trả phòng nhanh</p>
        </div>
        <div style="display: flex; gap: 12px; font-size: 0.8rem; font-weight: 600;">
            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; background-color: rgba(22, 163, 74, 0.08); color: #16a34a;">
                <i class="fa-solid fa-circle"></i> Còn trống
            </span>
            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; background-color: rgba(220, 38, 38, 0.08); color: #dc2626;">
                <i class="fa-solid fa-circle"></i> Đang ở
            </span>
            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; background-color: rgba(217, 119, 6, 0.08); color: #d97706;">
                <i class="fa-solid fa-circle"></i> Cần dọn dẹp
            </span>
            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; background-color: rgba(37, 99, 235, 0.08); color: #2563eb;">
                <i class="fa-solid fa-circle"></i> Đặt trước
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background-color: rgba(22, 163, 74, 0.08); color: #16a34a; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background-color: rgba(220, 38, 38, 0.08); color: #dc2626; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
            <i class="fa-solid fa-triangle-exclamation" style="margin-right: 8px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 24px;">
            @foreach (var room in Model)
            {
                string statusColor = "#64748b";
                string statusBg = "rgba(100, 116, 139, 0.08)";
                string iconClass = "fa-bed";

                switch (room.RoomStatus?.StatusCode)
                {
                    case "available":
                        statusColor = "#16a34a";
                        statusBg = "rgba(22, 163, 74, 0.08)";
                        break;
                    case "occupied":
                        statusColor = "#dc2626";
                        statusBg = "rgba(220, 38, 38, 0.08)";
                        iconClass = "fa-user-check";
                        break;
                    case "dirty":
                        statusColor = "#d97706";
                        statusBg = "rgba(217, 119, 6, 0.08)";
                        iconClass = "fa-broom";
                        break;
                    case "reserved":
                        statusColor = "#2563eb";
                        statusBg = "rgba(37, 99, 235, 0.08)";
                        iconClass = "fa-calendar-check";
                        break;
                }

                <div style="background: #ffffff; border: 1px solid var(--border-light); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; justify-content: space-between; box-shadow: var(--shadow-sm); min-height: 200px;">
                    <div>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <span style="font-size: 1.4rem; font-weight: 800; color: var(--text-primary);">P.@room.RoomNumber</span>
                            <span style="font-size: 0.75rem; font-weight: 600; padding: 4px 10px; border-radius: 20px; background-color: @statusBg; color: @statusColor; display: inline-flex; align-items: center; gap: 4px;">
                                <i class="fa-solid @iconClass"></i> @room.RoomStatus?.StatusName
                            </span>
                        </div>
                        <span style="font-size: 0.8rem; color: var(--text-muted); display: block; font-weight: 500;">@room.RoomType?.TypeName</span>
                        <span style="font-size: 0.95rem; font-weight: 700; color: var(--primary-color); display: block; margin-top: 4px;">@room.Price.ToString("N0")đ <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ đêm</span></span>
                    </div>

                    @if (room.RoomStatus?.StatusCode == "occupied" && !string.IsNullOrEmpty(room.CustomerName))
                    {
                        <div style="margin-top: 10px; font-size: 0.8rem; background-color: var(--bg-main); padding: 8px; border-radius: 6px; border-left: 3px solid #dc2626;">
                            <strong style="display:block; color:var(--text-primary);">Khách hàng: @room.CustomerName</strong>
                            <span style="color:var(--text-secondary);">SĐT: @room.CustomerPhone</span>
                        </div>
                    }

                    <div style="margin-top: 16px; border-top: 1px solid var(--border-light); padding-top: 12px; display: flex; gap: 8px; justify-content: flex-end;">
                        <a asp-action="UpdateStatus" asp-route-id="@room.Id" class="btn btn-outline" style="padding: 6px 10px; font-size: 0.75rem; border-radius: 6px;">
                            Trạng thái
                        </a>

                        @if (room.RoomStatus?.StatusCode == "dirty")
                        {
                            <form asp-action="UpdateStatus" asp-route-id="@room.Id" method="post" style="display:inline;">
                                <input type="hidden" name="statusCode" value="available" />
                                <button type="submit" class="btn btn-primary" style="padding: 6px 10px; font-size: 0.75rem; border-radius: 6px; background-color: #16a34a; border-color: #16a34a;">
                                    <i class="fa-solid fa-broom"></i> Đã dọn
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 48px;">
            <i class="fa-solid fa-hotel" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
            <p style="color: var(--text-secondary);">Chưa cấu hình sơ đồ phòng khách sạn.</p>
        </div>
    }
</div>
