@model HotelManagement.Areas.Admin.Models.Customer
@{
    ViewData["Title"] = "Thêm khách hàng mới - Lễ tân";
}

<div class="glass-panel" style="max-width: 600px; margin: 0 auto;">
    <div style="border-bottom: 1px solid var(--border-light); padding-bottom: 16px; margin-bottom: 24px;">
        <h1 class="section-title"><i class="fa-solid fa-user-plus"></i> Thêm khách hàng mới</h1>
        <p class="section-desc">Điền thông tin của khách lưu trú để đăng ký vào hệ thống</p>
    </div>

    <form asp-area="Receptionist" asp-controller="Customer" asp-action="Create" method="post" style="display: flex; flex-direction: column; gap: 16px;">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 0.85rem; background-color: rgba(220, 38, 38, 0.08); padding: 10px; border-radius: 8px;"></div>

        <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
            <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Họ và tên khách hàng</label>
            <input type="text" asp-for="FullName" class="form-input" placeholder="Ví dụ: Nguyễn Văn A" required style="padding: 10px; border: 1px solid var(--border-light); border-radius: 8px; outline: none;" />
            <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.75rem;"></span>
        </div>

        <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
            <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Địa chỉ Email</label>
            <input type="email" asp-for="Email" class="form-input" placeholder="name@email.com" required style="padding: 10px; border: 1px solid var(--border-light); border-radius: 8px; outline: none;" />
            <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Số điện thoại</label>
                <input type="tel" asp-for="PhoneNumber" class="form-input" placeholder="0901234567" required style="padding: 10px; border: 1px solid var(--border-light); border-radius: 8px; outline: none;" />
                <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
            <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Số CMND / CCCD / Hộ chiếu</label>
                <input type="text" asp-for="IdentityCard" class="form-input" placeholder="Số giấy tờ cá nhân..." required style="padding: 10px; border: 1px solid var(--border-light); border-radius: 8px; outline: none;" />
                <span asp-validation-for="IdentityCard" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>
        </div>

        <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
            <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary);">Địa chỉ liên hệ</label>
            <input type="text" asp-for="Address" class="form-input" placeholder="Nhập địa chỉ của khách hàng..." required style="padding: 10px; border: 1px solid var(--border-light); border-radius: 8px; outline: none;" />
            <span asp-validation-for="Address" class="text-danger" style="font-size: 0.75rem;"></span>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 12px; border-top: 1px solid var(--border-light); padding-top: 20px;">
            <a asp-action="Index" class="btn btn-outline" style="border-radius: 8px;">Quay lại</a>
            <button type="submit" class="btn btn-primary" style="border-radius: 8px;">
                <i class="fa-solid fa-floppy-disk"></i> Lưu khách hàng
            </button>
        </div>
    </form>
</div>
