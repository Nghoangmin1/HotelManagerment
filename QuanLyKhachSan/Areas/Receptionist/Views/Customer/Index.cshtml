@model IEnumerable<HotelManagement.Areas.Admin.Models.Customer>
@{
    ViewData["Title"] = "Quản lý khách hàng - Lễ tân";
}

<div class="glass-panel">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h1 class="section-title"><i class="fa-solid fa-users"></i> Quản lý khách hàng</h1>
            <p class="section-desc">Danh sách và thông tin hồ sơ của khách hàng trong hệ thống</p>
        </div>
        <a asp-action="Create" class="btn btn-primary" style="border-radius: 8px;">
            <i class="fa-solid fa-user-plus"></i> Thêm khách hàng mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background-color: rgba(22, 163, 74, 0.08); color: #16a34a; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <table style="width: 100%; border-collapse: collapse; margin-top: 16px; text-align: left; font-size: 0.9rem;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-light); color: var(--text-primary); font-weight: 700;">
                    <th style="padding: 12px 8px;">ID</th>
                    <th style="padding: 12px 8px;">Họ và tên</th>
                    <th style="padding: 12px 8px;">Số điện thoại</th>
                    <th style="padding: 12px 8px;">Số CMND / CCCD</th>
                    <th style="padding: 12px 8px;">Email</th>
                    <th style="padding: 12px 8px;">Địa chỉ</th>
                    <th style="padding: 12px 8px; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid var(--border-light); transition: background-color 0.15s ease;">
                        <td style="padding: 14px 8px; font-weight: 600;">#@item.Id</td>
                        <td style="padding: 14px 8px; font-weight: 600;">@item.FullName</td>
                        <td style="padding: 14px 8px;">@item.PhoneNumber</td>
                        <td style="padding: 14px 8px; font-family: var(--font-mono);">@item.IdentityCard</td>
                        <td style="padding: 14px 8px;">@item.Email</td>
                        <td style="padding: 14px 8px;">@item.Address</td>
                        <td style="padding: 14px 8px; text-align: center; display: flex; gap: 8px; justify-content: center;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 6px;">
                                <i class="fa-solid fa-pen-to-square"></i> Sửa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 48px;">
            <i class="fa-solid fa-users-slash" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 16px;"></i>
            <p style="color: var(--text-secondary);">Chưa có dữ liệu khách hàng nào được tạo.</p>
        </div>
    }
</div>
