@{
    ViewData["Title"] = "Thanh toán & Trả phòng - Lễ tân";
    var booking = ViewBag.Booking as HotelManagement.Areas.Admin.Models.Booking;
    var serviceUsages = ViewBag.ServiceUsages as IEnumerable<HotelManagement.Areas.Admin.Models.ServiceUsage>;
    int days = ViewBag.Days;
    decimal roomCost = ViewBag.RoomCost;
    decimal serviceCost = ViewBag.ServiceCost;
    decimal serviceUsagesCost = ViewBag.ServiceUsagesCost;
    decimal subTotal = ViewBag.SubTotal;
    decimal defaultTax = ViewBag.Tax;
    decimal defaultDiscount = ViewBag.Discount;
    decimal defaultTotalAmount = ViewBag.TotalAmount;
}

<div class="glass-panel" style="max-width: 900px; margin: 0 auto;">
    <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 24px; border-bottom: 1px solid var(--border-light); padding-bottom: 12px;">
        <i class="fa-solid fa-file-invoice-dollar" style="color:var(--primary-color); margin-right:8px;"></i> Thanh toán hóa đơn checkout & Trả phòng
    </h3>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background-color: rgba(220, 38, 38, 0.08); color: #dc2626; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 32px; align-items: start;">
        <!-- Left Column: Billing Breakdown details -->
        <div style="background: var(--bg-main); border: 1px solid var(--border-light); border-radius: 12px; padding: 24px;">
            <h4 style="font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0 0 16px 0; border-bottom: 1px solid var(--border-light); padding-bottom: 8px;">
                Chi tiết tiền phòng & dịch vụ
            </h4>

            <div style="font-size: 0.85rem; color: var(--text-secondary); display:flex; flex-direction:column; gap:8px; margin-bottom: 20px;">
                <p style="margin: 0;"><strong>Khách hàng:</strong> @booking?.Customer?.FullName</p>
                <p style="margin: 0;"><strong>Điện thoại:</strong> @booking?.Customer?.PhoneNumber</p>
                <p style="margin: 0;"><strong>Phòng lưu trú:</strong> P.@booking?.Room?.RoomNumber (@booking?.Room?.RoomType?.TypeName)</p>
                <p style="margin: 0;"><strong>Thời gian lưu trú:</strong> @booking?.CheckInDate.ToString("dd/MM/yyyy") - @DateTime.Now.ToString("dd/MM/yyyy") (@days đêm)</p>
            </div>

            <table style="width: 100%; border-collapse: collapse; font-size: 0.8rem; text-align: left;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-light); background: rgba(0,0,0,0.02)">
                        <th style="padding: 8px;">Diễn giải</th>
                        <th style="padding: 8px; text-align: center;">SL</th>
                        <th style="padding: 8px; text-align: right;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Room stay charge -->
                    <tr style="border-bottom: 1px solid var(--border-light);">
                        <td style="padding: 10px 8px;">
                            <strong>Tiền thuê phòng P.@booking?.Room?.RoomNumber</strong><br />
                            <small>@days đêm x @((booking?.Room?.Price ?? 0).ToString("N0"))đ</small>
                        </td>
                        <td style="padding: 10px 8px; text-align: center;">@days</td>
                        <td style="padding: 10px 8px; text-align: right; font-family: var(--font-mono)">@roomCost.ToString("N0")đ</td>
                    </tr>

                    <!-- Service Details (BookingDetails) -->
                    @if (booking?.BookingDetails != null && booking.BookingDetails.Any())
                    {
                        @foreach (var detail in booking.BookingDetails)
                        {
                            <tr style="border-bottom: 1px solid var(--border-light);">
                                <td style="padding: 10px 8px;">
                                    @detail.ServiceName <span style="font-size:0.7rem; color:var(--text-muted)">(Đăng ký trước)</span>
                                </td>
                                <td style="padding: 10px 8px; text-align: center;">@detail.Quantity</td>
                                <td style="padding: 10px 8px; text-align: right; font-family: var(--font-mono)">@((detail.ServicePrice * detail.Quantity).ToString("N0"))đ</td>
                            </tr>
                        }
                    }

                    <!-- Service Usages (ServiceUsages) -->
                    @if (serviceUsages != null && serviceUsages.Any())
                    {
                        @foreach (var usage in serviceUsages)
                        {
                            <tr style="border-bottom: 1px solid var(--border-light);">
                                <td style="padding: 10px 8px;">
                                    @usage.Service?.ServiceName <span style="font-size:0.7rem; color:#16a34a">(Sử dụng tại phòng)</span><br />
                                    <small>@usage.UsageDate.ToString("dd/MM HH:mm")</small>
                                </td>
                                <td style="padding: 10px 8px; text-align: center;">@usage.Quantity</td>
                                <td style="padding: 10px 8px; text-align: right; font-family: var(--font-mono)">@((usage.Quantity * (usage.Service?.Price ?? 0)).ToString("N0"))đ</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div style="margin-top: 16px; border-top: 2px solid var(--border-light); padding-top: 12px; display:flex; justify-content:space-between; font-size:0.95rem; font-weight:700;">
                <span style="color: var(--text-primary);">Tổng cộng chưa thuế (Tạm tính):</span>
                <span style="font-family: var(--font-mono)" id="lblSubTotal">@subTotal.ToString("N0")đ</span>
            </div>
        </div>

        <!-- Right Column: Checkout Payment Actions -->
        <div>
            <h4 style="font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0 0 16px 0; border-bottom: 1px solid var(--border-light); padding-bottom: 8px;">
                Thông tin thanh toán hóa đơn
            </h4>

            <form asp-action="Checkout" method="post" style="display:flex; flex-direction:column; gap:16px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="bookingId" value="@booking?.Id" />

                <!-- Discount Input -->
                <div class="form-field">
                    <label class="field-label">Giảm giá trực tiếp (VNĐ)</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-tags input-icon"></i>
                        <input type="number" id="txtDiscount" name="discount" value="0" min="0" step="5000" class="form-input input-with-icon" oninput="recalculateTotals()" />
                    </div>
                </div>

                <!-- Tax Input -->
                <div class="form-field">
                    <label class="field-label">Thuế VAT (VNĐ) <span style="font-weight:normal; font-size:0.75rem; color:var(--text-secondary)">(Mặc định 10%)</span></label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-percent input-icon"></i>
                        <input type="number" id="txtTax" name="tax" value="@((subTotal * 0.1m).ToString("0"))" min="0" step="1000" class="form-input input-with-icon" oninput="recalculateTotals()" />
                    </div>
                </div>

                <!-- Calculated Total amount payable -->
                <div style="background: rgba(var(--primary-rgb), 0.04); border-radius: 8px; padding: 16px; display:flex; justify-content:space-between; align-items:center; font-size:1.1rem; font-weight:800;">
                    <span style="color:var(--text-primary)">Khách cần thanh toán:</span>
                    <span style="color:var(--primary-color); font-family:var(--font-mono)" id="lblTotalAmount">@defaultTotalAmount.ToString("N0")đ</span>
                </div>

                <!-- Method input -->
                <div class="form-field">
                    <label class="field-label">Phương thức thanh toán</label>
                    <div class="input-wrapper">
                        <select name="method" class="form-input" required>
                            <option value="Cash">Cash (Tiền mặt)</option>
                            <option value="CreditCard">CreditCard (Thẻ tín dụng)</option>
                            <option value="BankTransfer">BankTransfer (Chuyển khoản)</option>
                        </select>
                    </div>
                </div>

                <!-- Amount Received -->
                <div class="form-field">
                    <label class="field-label">Số tiền khách đưa (VNĐ)</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-hand-holding-dollar input-icon"></i>
                        <input type="number" id="txtAmount" name="amount" value="@defaultTotalAmount.ToString("0")" min="0" step="1000" class="form-input input-with-icon" required oninput="calculateChange()" />
                    </div>
                </div>

                <!-- Change return calculation -->
                <div style="display:flex; justify-content:space-between; font-size:0.9rem; font-weight:600; color:var(--text-secondary); margin-bottom:8px;">
                    <span>Tiền thối lại cho khách:</span>
                    <span id="lblChange" style="font-family:var(--font-mono)">0đ</span>
                </div>

                <div style="display: flex; gap: 12px; justify-content: flex-end; border-top: 1px solid var(--border-light); padding-top: 16px; margin-top: 8px;">
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-outline">
                        Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-primary" style="background-color: #16a34a; border-color: #16a34a;">
                        <i class="fa-solid fa-check-double"></i> Xác nhận trả phòng & In hóa đơn
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const subTotal = @subTotal;

    function recalculateTotals() {
        let discount = parseFloat(document.getElementById('txtDiscount').value) || 0;
        let tax = parseFloat(document.getElementById('txtTax').value) || 0;

        let total = subTotal - discount + tax;
        if (total < 0) total = 0;

        document.getElementById('lblTotalAmount').innerText = total.toLocaleString('vi-VN') + 'đ';
        
        let amountInput = document.getElementById('txtAmount');
        // Auto-update amount input if it matches total
        if (parseFloat(amountInput.value) >= 0) {
            amountInput.value = Math.round(total);
        }
        calculateChange();
    }

    function calculateChange() {
        let totalText = document.getElementById('lblTotalAmount').innerText.replace(/[^\d]/g, '');
        let total = parseFloat(totalText) || 0;

        let amountReceived = parseFloat(document.getElementById('txtAmount').value) || 0;
        let change = amountReceived - total;

        if (change < 0) {
            document.getElementById('lblChange').innerText = 'Chưa đủ tiền thanh toán!';
            document.getElementById('lblChange').style.color = '#ef4444';
        } else {
            document.getElementById('lblChange').innerText = change.toLocaleString('vi-VN') + 'đ';
            document.getElementById('lblChange').style.color = '#16a34a';
        }
    }

    // Run once on load
    window.addEventListener('DOMContentLoaded', () => {
        calculateChange();
    });
</script>
