@model IEnumerable<HotelManagement.Areas.Admin.Models.Customer>
@{
    ViewData["Title"] = "Quản lý khách hàng - HotelManagement";
}

<div class="hotel-mockup-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-success); padding: 16px 24px; color: var(--color-success); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="glass-panel animate-fade" style="padding: 24px;">
        <div class="hotel-room-grid-header" style="margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;">
            <h3 style="font-size:1.2rem; font-weight:700; margin: 0;">
                <i class="fa-solid fa-users" style="color:var(--primary-color); margin-right:8px;"></i> Quản lý khách hàng lưu trú
            </h3>
            
            <div style="display: flex; gap: 12px; align-items: center;">
                <input type="text" id="customer-search-input" placeholder="Tìm kiếm nhanh khách hàng..." class="form-input" style="max-width: 250px; padding: 8px 16px; font-size: 0.85rem;" />
                <a asp-action="Create" class="btn btn-primary" style="white-space: nowrap;">
                    <i class="fa-solid fa-user-plus"></i> Thêm khách hàng
                </a>
            </div>
        </div>

        <div class="mock-table" style="background:#ffffff; box-shadow:none;">
            <div class="mock-table-header" style="grid-template-columns: 1.5fr 1fr 1fr 1.5fr 1fr 1.5fr; font-size: 0.85rem; padding: 12px 16px;">
                <div>Họ và tên</div>
                <div>Số điện thoại</div>
                <div>Số CMND/CCCD</div>
                <div>Email</div>
                <div>Ngày tạo</div>
                <div style="text-align: right;">Thao tác</div>
            </div>
            <div id="customer-rows-container">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="mock-table-row customer-row" style="grid-template-columns: 1.5fr 1fr 1fr 1.5fr 1fr 1.5fr; font-size: 0.85rem; padding: 16px 16px;" data-search-text="@item.FullName.ToLower() @item.PhoneNumber @item.IdentityCard @item.Email.ToLower()">
                            <div style="font-weight: 700; color: var(--secondary-color);">@item.FullName</div>
                            <div style="font-family:var(--font-mono)">@item.PhoneNumber</div>
                            <div style="font-family:var(--font-mono)">@item.IdentityCard</div>
                            <div>@item.Email</div>
                            <div style="font-size:0.8rem; color:var(--text-secondary)">@item.CreatedAt.AddHours(7).ToString("dd/MM/yyyy")</div>
                            <div style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline" style="padding: 6px 10px; font-size:0.75rem; border-color: var(--primary-color); color: var(--primary-color);">
                                    <i class="fa-solid fa-pen-to-square"></i> Sửa
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng này khỏi hệ thống? Lưu ý: Hành động này có thể bị hạn chế nếu khách hàng đang có các giao dịch đặt phòng hiện hữu.')" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger" style="padding: 6px 10px; font-size:0.75rem;">
                                        <i class="fa-solid fa-trash-can"></i> Xóa
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center" style="padding: 48px; color: var(--text-muted);">
                        <i class="fa-solid fa-user-slash" style="font-size: 3rem; margin-bottom: 12px; display:block;"></i>
                        Chưa có khách hàng nào trong hệ thống.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('customer-search-input');
        const rows = document.querySelectorAll('.customer-row');

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const query = this.value.toLowerCase().trim();
                rows.forEach(row => {
                    const text = row.getAttribute('data-search-text') || '';
                    if (text.includes(query)) {
                        row.style.display = 'grid';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        }
    });
</script>
}
