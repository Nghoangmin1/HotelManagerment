@model IEnumerable<HotelManagement.Areas.Admin.Models.Payment>

@{
    ViewData["Title"] = "Lịch sử giao dịch thanh toán - HotelManagement";
}

<div class="hotel-mockup-container">
    <div class="glass-panel animate-fade" style="padding: 24px;">
        <div class="hotel-room-grid-header" style="margin-bottom: 24px;">
            <h3 style="font-size:1.2rem; font-weight:700;">
                <i class="fa-solid fa-receipt" style="color:var(--primary-color); margin-right:8px;"></i> Lịch sử giao dịch thanh toán
            </h3>
            <a asp-action="Invoices" class="btn btn-outline">
                <i class="fa-solid fa-file-invoice"></i> Danh sách hóa đơn
            </a>
        </div>

        <div class="mock-table" style="background:#ffffff; box-shadow:none;">
            <div class="mock-table-header" style="grid-template-columns: 1.5fr 1.5fr 2fr 1.5fr 1.5fr 1.5fr 1.5fr; font-size: 0.85rem; padding: 12px 16px;">
                <div>Mã GD</div>
                <div>Mã Đặt Phòng</div>
                <div>Khách hàng</div>
                <div>Số tiền</div>
                <div>Phương thức</div>
                <div>Trạng thái</div>
                <div>Ngày giao dịch</div>
            </div>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var statusClass = item.Status.ToLower() switch
                    {
                        "completed" => "available",
                        "pending" => "reserved",
                        "failed" => "dirty",
                        _ => ""
                    };
                    
                    var methodLabel = item.PaymentMethod switch
                    {
                        "Cash" => "Tiền mặt",
                        "CreditCard" => "Thẻ tín dụng",
                        "BankTransfer" => "Chuyển khoản",
                        "Online" => "Trực tuyến",
                        _ => item.PaymentMethod
                    };

                    <div class="mock-table-row" style="grid-template-columns: 1.5fr 1.5fr 2fr 1.5fr 1.5fr 1.5fr 1.5fr; font-size: 0.85rem; padding: 16px 16px;">
                        <div style="font-family:var(--font-mono); font-weight: 800; color: var(--secondary-color);">
                            @(string.IsNullOrEmpty(item.TransactionId) ? "N/A" : item.TransactionId)
                        </div>
                        <div style="font-weight:600;">#@item.BookingId</div>
                        <div>@item.Booking?.Customer?.FullName</div>
                        <div style="font-family:var(--font-mono); font-weight:600;">@item.Amount.ToString("N0")đ</div>
                        <div>@methodLabel</div>
                        <div>
                            <span class="mock-status @statusClass" style="padding: 4px 10px; font-size:0.75rem;">
                                @item.Status
                            </span>
                        </div>
                        <div>@item.PaymentDate.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }
            }
            else
            {
                <div class="text-center" style="padding: 48px; color: var(--text-muted);">
                    <i class="fa-solid fa-money-bill-transfer" style="font-size: 3rem; margin-bottom: 12px; display:block;"></i>
                    Chưa có giao dịch thanh toán nào được thực hiện.
                </div>
            }
        </div>
    </div>
</div>
