@model IEnumerable<HotelManagement.Areas.Admin.Models.BookingReportModel>
@{
    ViewData["Title"] = "Báo Cáo Đặt Phòng";
}

<div class="hotel-mockup-container">
    <div class="flex-align-center justify-between" style="margin-bottom: 24px;">
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--primary-color);">
            <i class="fa-solid fa-calendar-check" style="margin-right: 8px;"></i> Báo Cáo Đặt Phòng
        </h2>
        <a href="@Url.Action("ExportBookingReport", "Report", new { startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })" class="btn btn-primary" style="display:flex; align-items:center; gap:8px;">
            <i class="fa-solid fa-file-csv"></i> Xuất CSV
        </a>
    </div>

    <!-- Filter Form -->
    <div class="glass-panel" style="padding: 24px; margin-bottom: 24px;">
        <form method="get" style="display:grid; grid-template-columns: 1fr 1fr auto; gap: 16px; align-items: end;">
            <div class="form-field" style="margin-bottom: 0;">
                <label class="field-label" style="font-weight:600;">Từ Ngày</label>
                <input type="date" name="startDate" class="form-input" value="@ViewBag.StartDate" />
            </div>
            <div class="form-field" style="margin-bottom: 0;">
                <label class="field-label" style="font-weight:600;">Đến Ngày</label>
                <input type="date" name="endDate" class="form-input" value="@ViewBag.EndDate" />
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="padding: 10px 24px;">
                    <i class="fa-solid fa-filter"></i> Lọc Dữ Liệu
                </button>
            </div>
        </form>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Data Table -->
    <div class="glass-panel" style="padding: 24px;">
        <div class="mock-table">
            <div class="mock-table-header" style="grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;">
                <div style="font-weight:700;">Ngày / Tháng</div>
                <div style="font-weight:700; text-align:center;">Tổng Đặt</div>
                <div style="font-weight:700; text-align:center;">Hoàn Thành</div>
                <div style="font-weight:700; text-align:center;">Đã Hủy</div>
                <div style="font-weight:700; text-align:right;">Tỷ Lệ (Hoàn thành)</div>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center" style="padding: 32px; color: var(--text-muted);">
                    <i class="fa-solid fa-box-open" style="font-size: 2rem; margin-bottom: 12px; display:block;"></i>
                    Không có dữ liệu trong khoảng thời gian này.
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    <div class="mock-table-row animate-fade" style="grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr; padding: 12px 16px;">
                        <div style="font-weight: 600;">@item.DateLabel</div>
                        <div style="text-align:center; font-weight: 700;">@item.TotalBookings</div>
                        <div style="text-align:center; color: var(--color-success);"><i class="fa-solid fa-check-circle" style="margin-right:4px;"></i>@item.CompletedBookings</div>
                        <div style="text-align:center; color: var(--color-danger);"><i class="fa-solid fa-times-circle" style="margin-right:4px;"></i>@item.CancelledBookings</div>
                        <div style="text-align:right;">
                            <div style="background:var(--border-light); height:8px; border-radius:4px; overflow:hidden; margin-bottom:4px; margin-top:6px;">
                                <div style="width: @(item.CompletionRate)%; background:var(--color-success); height:100%;"></div>
                            </div>
                            <span style="font-size:0.8rem; font-weight:600; font-family:var(--font-mono)">@(item.CompletionRate)%</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
