@model IEnumerable<HotelManagement.Areas.Admin.Models.RoomStatisticModel>
@{
    ViewData["Title"] = "Thống Kê Tình Trạng Phòng";
}

<div class="hotel-mockup-container">
    <div class="flex-align-center justify-between" style="margin-bottom: 24px;">
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--primary-color);">
            <i class="fa-solid fa-bed" style="margin-right: 8px;"></i> Thống Kê Tình Trạng Phòng
        </h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <!-- Chart Section -->
        <div class="glass-panel animate-fade" style="padding: 24px; display:flex; flex-direction:column; justify-content:center; align-items:center; min-height: 400px;">
            <canvas id="roomStatusChart" style="max-height: 350px; width:100%;"></canvas>
        </div>

        <!-- Data Section -->
        <div class="glass-panel animate-fade" style="padding: 24px; animation-delay: 0.1s;">
            <div class="mock-table">
                <div class="mock-table-header" style="grid-template-columns: 2fr 1fr 1fr 1fr;">
                    <div style="font-weight:700;">Trạng Thái</div>
                    <div style="font-weight:700; text-align:center;">Mã</div>
                    <div style="font-weight:700; text-align:center;">Số Lượng</div>
                    <div style="font-weight:700; text-align:right;">Tỷ Lệ (%)</div>
                </div>
                @if (!Model.Any())
                {
                    <div class="text-center" style="padding: 32px; color: var(--text-muted);">
                        <i class="fa-solid fa-ban" style="font-size: 2rem; margin-bottom: 12px; display:block;"></i>
                        Chưa có dữ liệu phòng.
                    </div>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <div class="mock-table-row" style="grid-template-columns: 2fr 1fr 1fr 1fr; padding: 16px;">
                            <div style="font-weight: 600; display:flex; align-items:center;">
                                <i class="fa-solid fa-circle color-indicator" style="font-size: 0.6rem; margin-right: 8px;"></i>
                                @item.StatusName
                            </div>
                            <div style="text-align:center;"><span style="background:var(--border-light); padding:4px 8px; border-radius:4px; font-size:0.8rem;">@item.StatusCode</span></div>
                            <div style="text-align:center; font-size:1.1rem; font-weight:700;">@item.RoomCount</div>
                            <div style="text-align:right; font-weight: 700; color: var(--primary-color);">@item.Percentage%</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var ctx = document.getElementById('roomStatusChart').getContext('2d');
            
            var labels = @Html.Raw(Json.Serialize(Model.Select(m => m.StatusName)));
            var data = @Html.Raw(Json.Serialize(Model.Select(m => m.RoomCount)));
            
            var myChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: [
                            'rgba(54, 162, 235, 0.8)',
                            'rgba(255, 99, 132, 0.8)',
                            'rgba(255, 206, 86, 0.8)',
                            'rgba(75, 192, 192, 0.8)',
                            'rgba(153, 102, 255, 0.8)'
                        ],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: {
                                    family: "'Inter', sans-serif",
                                    size: 14
                                }
                            }
                        }
                    },
                    cutout: '65%'
                }
            });
            
            // Apply colors to table rows
            const bgColors = [
                '#36A2EB', '#FF6384', '#FFCE56', '#4BC0C0', '#9966FF'
            ];
            const rows = document.querySelectorAll('.color-indicator');
            rows.forEach((icon, index) => {
                if (bgColors[index]) {
                    icon.style.color = bgColors[index];
                }
            });
        });
    </script>
}
