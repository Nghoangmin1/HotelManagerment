@model IEnumerable<HotelManagement.Areas.Admin.Models.RevenueReportModel>
@{
    ViewData["Title"] = "Báo Cáo Doanh Thu";
}

<div class="hotel-mockup-container">
    <div class="flex-align-center justify-between" style="margin-bottom: 24px;">
        <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--primary-color);">
            <i class="fa-solid fa-chart-line" style="margin-right: 8px;"></i> Báo Cáo Doanh Thu
        </h2>
        <a href="@Url.Action("ExportRevenueReport", "Report", new { startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })" class="btn btn-primary" style="display:flex; align-items:center; gap:8px;">
            <i class="fa-solid fa-file-csv"></i> Xuất CSV
        </a>
    </div>

    <!-- Filter Form -->
    <div class="glass-panel" style="padding: 24px; margin-bottom: 24px;">
        <form method="get" style="display:grid; grid-template-columns: 1fr 1fr auto; gap: 16px; align-items: end;">
            <div class="form-field" style="margin-bottom: 0;">
                <label class="field-label" style="font-weight:600;">Từ Ngày</label>
                <input type="date" name="startDate" class="form-input" value="@ViewBag.StartDate" />
            </div>
            <div class="form-field" style="margin-bottom: 0;">
                <label class="field-label" style="font-weight:600;">Đến Ngày</label>
                <input type="date" name="endDate" class="form-input" value="@ViewBag.EndDate" />
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="padding: 10px 24px;">
                    <i class="fa-solid fa-filter"></i> Lọc Dữ Liệu
                </button>
            </div>
        </form>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Data Table -->
    <div class="glass-panel" style="padding: 24px;">
        <div class="mock-table">
            <div class="mock-table-header" style="grid-template-columns: 2fr 1fr 1fr 1.5fr;">
                <div style="font-weight:700;">Ngày / Tháng</div>
                <div style="font-weight:700; text-align:right;">Tiền Phòng</div>
                <div style="font-weight:700; text-align:right;">Dịch Vụ</div>
                <div style="font-weight:700; text-align:right;">Tổng Doanh Thu</div>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center" style="padding: 32px; color: var(--text-muted);">
                    <i class="fa-solid fa-inbox" style="font-size: 2rem; margin-bottom: 12px; display:block;"></i>
                    Không có dữ liệu trong khoảng thời gian này.
                </div>
            }
            else
            {
                foreach (var item in Model)
                {
                    <div class="mock-table-row animate-fade" style="grid-template-columns: 2fr 1fr 1fr 1.5fr; padding: 12px 16px;">
                        <div style="font-weight: 600;">@item.DateLabel</div>
                        <div style="color: var(--color-success); text-align:right; font-family:var(--font-mono)">@item.RoomRevenue.ToString("N0") VNĐ</div>
                        <div style="color: var(--color-info); text-align:right; font-family:var(--font-mono)">@item.ServiceRevenue.ToString("N0") VNĐ</div>
                        <div style="text-align:right; font-weight: 700; color: var(--primary-color); font-family:var(--font-mono)">@item.TotalRevenue.ToString("N0") VNĐ</div>
                    </div>
                }
            }
        </div>
    </div>
</div>
