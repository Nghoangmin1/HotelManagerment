@model HotelManagement.Models.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - HotelManagement</title>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            z-index: 1;
        }
        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--bg-surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 40px 32px;
            box-shadow: var(--shadow-md);
        }
        .login-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .login-logo {
            width: 48px;
            height: 48px;
            background: var(--primary-glow);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-inverse);
            font-weight: 800;
            font-size: 1.4rem;
            margin: 0 auto 16px auto;
            box-shadow: var(--shadow-sm);
        }
        .login-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--secondary-color);
        }
        .login-subtitle {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 6px;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card animate-fade">
            <div class="login-header">
                <div class="login-logo"><i class="fa-solid fa-key"></i></div>
                <h1 class="login-title">Quên mật khẩu?</h1>
                <p class="login-subtitle">Nhập email đăng ký của bạn để khôi phục mật khẩu</p>
            </div>

            <form asp-area="Admin" asp-controller="Account" asp-action="ForgotPassword" method="post" class="element-group" style="gap: 16px;">
                <div asp-validation-summary="All" class="field-error-msg" style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; color: var(--color-danger); font-size: 0.85rem;"></div>
                
                <div class="form-field">
                    <label class="field-label" asp-for="Email">Email tài khoản</label>
                    <div class="input-wrapper">
                        <i class="fa-regular fa-envelope input-icon"></i>
                        <input asp-for="Email" class="form-input input-with-icon" placeholder="Nhập địa chỉ email..." required autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 4px; display: block;"></span>
                </div>

                <div style="margin-top: 12px; display: flex; flex-direction: column; gap: 12px;">
                    <button type="submit" class="btn btn-primary w-full" style="padding: 12px 18px;">
                        <i class="fa-solid fa-paper-plane"></i> Gửi liên kết đặt lại
                    </button>
                    
                    <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="btn text-center" style="background: transparent; border: 1px solid var(--border-light); color: var(--text-secondary); padding: 10px 18px; text-decoration: none; border-radius: var(--radius-md); font-weight: 600; font-size: 0.9rem;">
                        <i class="fa-solid fa-arrow-left"></i> Quay lại Đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>
