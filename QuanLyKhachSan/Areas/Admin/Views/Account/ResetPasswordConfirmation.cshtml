@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu thành công - HotelManagement</title>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            z-index: 1;
        }
        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--bg-surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 40px 32px;
            box-shadow: var(--shadow-md);
        }
        .login-header {
            text-align: center;
            margin-bottom: 24px;
        }
        .login-logo {
            width: 56px;
            height: 56px;
            background: var(--color-success-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-success);
            font-size: 1.6rem;
            margin: 0 auto 16px auto;
            box-shadow: var(--shadow-sm);
        }
        .login-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--secondary-color);
        }
        .login-subtitle {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-top: 10px;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card animate-fade">
            <div class="login-header">
                <div class="login-logo"><i class="fa-solid fa-circle-check"></i></div>
                <h1 class="login-title">Thành công!</h1>
                <p class="login-subtitle">
                    Mật khẩu của bạn đã được đặt lại thành công. Bây giờ bạn có thể đăng nhập lại hệ thống bằng mật khẩu mới.
                </p>
            </div>

            <div style="margin-top: 24px;">
                <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="btn btn-primary w-full" style="padding: 12px 18px; text-decoration: none; border-radius: var(--radius-md); font-weight: 600; display: inline-block; text-align: center;">
                    <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập ngay
                </a>
            </div>
        </div>
    </div>

</body>
</html>
