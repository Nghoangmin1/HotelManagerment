@{
    Layout = null;
    string? devResetLink = ViewBag.DevResetLink as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác nhận khôi phục mật khẩu - HotelManagement</title>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            z-index: 1;
        }
        .login-card {
            width: 100%;
            max-width: 450px;
            background: var(--bg-surface);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 40px 32px;
            box-shadow: var(--shadow-md);
        }
        .login-header {
            text-align: center;
            margin-bottom: 24px;
        }
        .login-logo {
            width: 56px;
            height: 56px;
            background: var(--color-success-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-success);
            font-size: 1.6rem;
            margin: 0 auto 16px auto;
            box-shadow: var(--shadow-sm);
        }
        .login-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--secondary-color);
        }
        .login-subtitle {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-top: 10px;
            line-height: 1.6;
        }
        .dev-box {
            background: var(--color-warning-bg);
            border: 1px dashed var(--color-warning);
            border-radius: var(--radius-md);
            padding: 16px;
            margin: 20px 0;
            font-size: 0.85rem;
            text-align: left;
        }
        .dev-title {
            color: var(--color-warning);
            font-weight: 700;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .dev-link {
            word-break: break-all;
            background: #fff;
            padding: 8px 10px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border-light);
            display: block;
            margin: 8px 0;
            text-decoration: none;
            color: var(--primary-color);
            font-weight: 600;
            font-family: var(--font-mono);
            font-size: 0.75rem;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card animate-fade">
            <div class="login-header">
                <div class="login-logo"><i class="fa-solid fa-circle-check"></i></div>
                <h1 class="login-title">Yêu cầu đã được gửi</h1>
                <p class="login-subtitle">
                    Một email hướng dẫn đã được gửi tới địa chỉ email đăng ký của bạn. Vui lòng kiểm tra hộp thư đến (và thư rác) để hoàn thành các bước đặt lại mật khẩu.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(devResetLink))
            {
                <div class="dev-box">
                    <div class="dev-title">
                        <i class="fa-solid fa-code"></i> Chế độ phát triển (Development Mode)
                    </div>
                    <p style="color: var(--text-secondary);">
                        Do ứng dụng đang chạy local và chưa gửi mail thực tế, bạn có thể click trực tiếp vào link dưới đây để đặt lại mật khẩu:
                    </p>
                    <a href="@devResetLink" class="dev-link">
                        @devResetLink
                    </a>
                    <button onclick="navigator.clipboard.writeText('@devResetLink'); showToast();" class="btn btn-secondary w-full" style="padding: 6px 12px; font-size: 0.8rem; background: #fff; border: 1px solid var(--border-light); color: var(--text-primary); cursor: pointer; border-radius: var(--radius-sm);">
                        <i class="fa-regular fa-copy"></i> Sao chép liên kết
                    </button>
                </div>
            }

            <div style="margin-top: 12px; text-align: center;">
                <a asp-area="Admin" asp-controller="Account" asp-action="Login" class="btn btn-primary w-full" style="padding: 12px 18px; text-decoration: none; border-radius: var(--radius-md); font-weight: 600; display: inline-block;">
                    <i class="fa-solid fa-right-to-bracket"></i> Trở về Đăng nhập
                </a>
            </div>
        </div>
    </div>

    <!-- Toast Notification for Copy success -->
    <div id="copy-toast">
        <i class="fa-solid fa-circle-check" style="color: var(--color-success); margin-right: 6px;"></i> Đã sao chép liên kết!
    </div>

    <script>
        function showToast() {
            var toast = document.getElementById("copy-toast");
            toast.className = "show";
            setTimeout(function(){ toast.className = toast.className.replace("show", ""); }, 3000);
        }
    </script>
</body>
</html>
