@model HotelManagement.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div style="max-width: 550px; margin: 0 auto;">
    <div class="section-header">
        <h2 class="section-title">
            <i class="fa-solid fa-key"></i> Đổi Mật Khẩu
        </h2>
        <p class="section-desc">Thay đổi mật khẩu đăng nhập vào tài khoản của bạn</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="glass-panel animate-fade" style="padding: 32px;">
        <form asp-area="Admin" asp-controller="Account" asp-action="ChangePassword" method="post" class="element-group" style="gap: 20px;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="field-error-msg" style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; color: var(--color-danger); font-size: 0.85rem;"></div>

            <div class="form-field">
                <label class="field-label" asp-for="OldPassword">Mật khẩu hiện tại</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-lock input-icon"></i>
                    <input asp-for="OldPassword" class="form-input input-with-icon" placeholder="Nhập mật khẩu hiện tại..." required />
                </div>
                <span asp-validation-for="OldPassword" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-field">
                <label class="field-label" asp-for="NewPassword">Mật khẩu mới</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-key input-icon"></i>
                    <input asp-for="NewPassword" class="form-input input-with-icon" placeholder="Nhập mật khẩu mới..." required />
                </div>
                <span asp-validation-for="NewPassword" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 4px; display: block;"></span>
            </div>

            <div class="form-field">
                <label class="field-label" asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-shield-halved input-icon"></i>
                    <input asp-for="ConfirmPassword" class="form-input input-with-icon" placeholder="Nhập lại mật khẩu mới..." required />
                </div>
                <span asp-validation-for="ConfirmPassword" style="color: var(--color-danger); font-size: 0.8rem; margin-top: 4px; display: block;"></span>
            </div>

            <div style="margin-top: 12px; display: flex; gap: 12px;">
                <button type="submit" class="btn btn-primary" style="flex: 1; padding: 12px 18px;">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                </button>
                <a asp-area="Admin" asp-controller="Home" asp-action="Dashboard" class="btn" style="background: transparent; border: 1px solid var(--border-light); color: var(--text-secondary); padding: 12px 18px; text-decoration: none; border-radius: var(--radius-md); font-weight: 600; font-size: 0.9rem; text-align: center;">
                    Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>
