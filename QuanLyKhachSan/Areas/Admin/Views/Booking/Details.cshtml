@model HotelManagement.Areas.Admin.Models.Booking
@{
    ViewData["Title"] = $"Chi tiết đặt phòng #{Model.Id} - HotelManagement";
    
    // Calculate stay duration
    int stayDays = 1;
    if (Model.CheckOutDate.HasValue)
    {
        stayDays = (Model.CheckOutDate.Value.Date - Model.CheckInDate.Date).Days;
        if (stayDays < 1) stayDays = 1;
    }
    
    decimal roomCost = (Model.Room?.Price ?? 0) * stayDays;
    decimal servicesCost = 0;
    foreach(var s in Model.BookingDetails)
    {
        servicesCost += s.ServicePrice * s.Quantity;
    }

    string statusLabel = "Chờ xử lý";
    string statusClass = "dirty";
    switch(Model.Status)
    {
        case "Confirmed":
            statusLabel = "Đã xác nhận";
            statusClass = "reserved";
            break;
        case "CheckedIn":
            statusLabel = "Đang lưu trú";
            statusClass = "occupied";
            break;
        case "CheckedOut":
            statusLabel = "Đã trả phòng";
            statusClass = "available";
            break;
        case "Cancelled":
            statusLabel = "Đã hủy";
            statusClass = "danger";
            break;
    }
}

<div class="hotel-mockup-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-success); padding: 16px 24px; color: var(--color-success); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div style="margin-bottom: 20px; display:flex; justify-content:space-between; align-items:center;">
        <a asp-action="Index" class="btn btn-outline" style="padding: 8px 16px;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>
        <div style="display:flex; gap:10px;">
            @if (Model.Status == "Pending")
            {
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="status" value="Confirmed" />
                    <button type="submit" class="btn btn-success" style="background-color: var(--primary-color); border-color: var(--primary-color);">
                        <i class="fa-solid fa-check"></i> Xác nhận (Duyệt)
                    </button>
                </form>
            }
            @if (Model.Status == "Pending" || Model.Status == "Confirmed")
            {
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="status" value="CheckedIn" />
                    <button type="submit" class="btn btn-primary" style="background-color: var(--color-success); border-color: var(--color-success);">
                        <i class="fa-solid fa-key"></i> Nhận phòng (Check-In)
                    </button>
                </form>
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="status" value="Cancelled" />
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Bạn có chắc chắn muốn hủy đặt phòng này?')">
                        <i class="fa-solid fa-ban"></i> Hủy đặt phòng
                    </button>
                </form>
            }
            else if (Model.Status == "CheckedIn")
            {
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="status" value="CheckedOut" />
                    <button type="submit" class="btn btn-primary" style="background-color: var(--secondary-color); border-color: var(--secondary-color);">
                        <i class="fa-solid fa-receipt"></i> Trả phòng & Thanh toán (Check-Out)
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="hotel-main-grid" style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 24px;">
        <!-- Left Column: Details -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <!-- Booking details -->
            <div class="glass-panel" style="padding: 24px; margin-bottom: 0;">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom: 1px solid var(--border-light); padding-bottom: 12px; margin-bottom: 16px;">
                    <h4 style="font-size: 1rem; font-weight:700; margin:0;">
                        <i class="fa-solid fa-circle-info" style="color:var(--primary-color);"></i> Thông tin đặt phòng #@Model.Id
                    </h4>
                    <span class="mock-status @statusClass" style="padding: 4px 12px; font-size: 0.75rem;">
                        @statusLabel
                    </span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Ngày nhận phòng:</span>
                    <span class="detail-value" style="font-weight:600;">@Model.CheckInDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Ngày trả phòng:</span>
                    <span class="detail-value" style="font-weight:600;">@(Model.CheckOutDate.HasValue ? Model.CheckOutDate.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa xác định")</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Số đêm lưu trú:</span>
                    <span class="detail-value" style="font-weight:600;">@stayDays đêm</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Tổng doanh thu tính:</span>
                    <span class="detail-value" style="font-weight:800; color:var(--primary-color); font-family:var(--font-mono); font-size:1.1rem;">@Model.TotalPrice.ToString("N0")đ</span>
                </div>
            </div>

            <!-- Customer details -->
            <div class="glass-panel" style="padding: 24px; margin-bottom: 0;">
                <h4 style="font-size: 1rem; font-weight:700; border-bottom: 1px solid var(--border-light); padding-bottom: 12px; margin-bottom: 16px;">
                    <i class="fa-solid fa-user-shield" style="color:var(--primary-color);"></i> Thông tin khách hàng
                </h4>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Họ và tên:</span>
                    <span class="detail-value" style="font-weight:600;">@Model.Customer?.FullName</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Số điện thoại:</span>
                    <span class="detail-value" style="font-family:var(--font-mono)">@Model.Customer?.PhoneNumber</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">CMND/CCCD:</span>
                    <span class="detail-value" style="font-family:var(--font-mono)">@Model.Customer?.IdentityCard</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Email:</span>
                    <span class="detail-value">@Model.Customer?.Email</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Địa chỉ:</span>
                    <span class="detail-value">@Model.Customer?.Address</span>
                </div>
            </div>

            <!-- Room details -->
            <div class="glass-panel" style="padding: 24px; margin-bottom: 0;">
                <h4 style="font-size: 1rem; font-weight:700; border-bottom: 1px solid var(--border-light); padding-bottom: 12px; margin-bottom: 16px;">
                    <i class="fa-solid fa-door-open" style="color:var(--primary-color);"></i> Thông tin phòng lưu trú
                </h4>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Số phòng:</span>
                    <span class="detail-value" style="font-weight:800; color:var(--secondary-color)">P.@Model.Room?.RoomNumber</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Loại phòng:</span>
                    <span class="detail-value" style="font-weight:600;">@Model.Room?.RoomType?.TypeName</span>
                </div>
                <div class="detail-row" style="display:flex; justify-content:space-between; font-size:0.9rem;">
                    <span class="detail-label" style="color:var(--text-secondary)">Đơn giá mỗi đêm:</span>
                    <span class="detail-value" style="font-family:var(--font-mono)">@Model.Room?.Price.ToString("N0")đ</span>
                </div>
            </div>
        </div>

        <!-- Right Column: Services Bill and Add Service -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <!-- Services table -->
            <div class="glass-panel" style="padding: 24px; margin-bottom: 0;">
                <h4 style="font-size: 1rem; font-weight:700; border-bottom: 1px solid var(--border-light); padding-bottom: 12px; margin-bottom: 16px;">
                    <i class="fa-solid fa-file-invoice-dollar" style="color:var(--primary-color);"></i> Bảng hóa đơn dịch vụ bổ sung
                </h4>
                
                <div class="mock-table" style="background:#ffffff; box-shadow:none;">
                    <div class="mock-table-header" style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr; font-size: 0.8rem; padding: 8px 12px;">
                        <div>Tên dịch vụ</div>
                        <div>Đơn giá</div>
                        <div>Số lượng</div>
                        <div>Thành tiền</div>
                        <div style="text-align: right;">Xóa</div>
                    </div>
                    
                    <!-- Base Room Charge -->
                    <div class="mock-table-row" style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr; font-size: 0.8rem; padding: 12px; background: #f8fafc; font-weight: 500;">
                        <div style="font-weight:600;">Tiền phòng (Stay Charge)</div>
                        <div style="font-family:var(--font-mono)">@Model.Room?.Price.ToString("N0")đ</div>
                        <div>@stayDays đ</div>
                        <div style="font-family:var(--font-mono); font-weight:600;">@roomCost.ToString("N0")đ</div>
                        <div style="text-align: right; color: var(--text-muted); font-size:0.75rem;">-</div>
                    </div>

                    @if (Model.BookingDetails != null && Model.BookingDetails.Any())
                    {
                        foreach(var detail in Model.BookingDetails)
                        {
                            decimal subtotal = detail.ServicePrice * detail.Quantity;
                            <div class="mock-table-row" style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr; font-size: 0.8rem; padding: 12px;">
                                <div style="font-weight:600;">@detail.ServiceName</div>
                                <div style="font-family:var(--font-mono)">@detail.ServicePrice.ToString("N0")đ</div>
                                <div>x@detail.Quantity</div>
                                <div style="font-family:var(--font-mono); font-weight:600;">@subtotal.ToString("N0")đ</div>
                                <div style="display:flex; justify-content:flex-end;">
                                    @if(Model.Status != "CheckedOut" && Model.Status != "Cancelled")
                                    {
                                        <form asp-action="DeleteService" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn bỏ dịch vụ này?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@detail.Id" />
                                            <input type="hidden" name="bookingId" value="@Model.Id" />
                                            <button type="submit" style="background:none; border:none; color:var(--color-danger); cursor:pointer; font-size:0.85rem;">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted)">-</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                
                <div style="border-top: 1px dashed var(--border-light); margin-top: 16px; padding-top: 16px; display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-weight:700; color:var(--secondary-color)">TỔNG CỘNG HÓA ĐƠN:</span>
                    <span style="font-size:1.3rem; font-weight:900; color:var(--primary-color); font-family:var(--font-mono)">@Model.TotalPrice.ToString("N0")đ</span>
                </div>
            </div>

            <!-- Add Service form -->
            @if(Model.Status != "CheckedOut" && Model.Status != "Cancelled")
            {
                <div class="glass-panel" style="padding: 24px; margin-bottom: 0;">
                    <h4 style="font-size: 1rem; font-weight:700; border-bottom: 1px solid var(--border-light); padding-bottom: 12px; margin-bottom: 16px;">
                        <i class="fa-solid fa-cart-plus" style="color:var(--primary-color);"></i> Thêm dịch vụ tiêu dùng
                    </h4>
                    
                    <form asp-action="AddService" method="post" style="display:flex; flex-direction:column; gap:16px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@Model.Id" />
                        
                        <div class="form-field">
                            <label class="field-label">Tên dịch vụ</label>
                            <input type="text" name="serviceName" class="form-input" placeholder="Ví dụ: Nước suối, Giặt là, Nước ngọt..." required />
                        </div>
                        
                        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                            <div class="form-field">
                                <label class="field-label">Đơn giá (VNĐ)</label>
                                <input type="number" name="servicePrice" step="500" class="form-input" value="15000" required />
                            </div>
                            <div class="form-field">
                                <label class="field-label">Số lượng</label>
                                <input type="number" name="quantity" class="form-input" value="1" min="1" required />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" style="margin-top:8px;">
                            <i class="fa-solid fa-plus"></i> Thêm dịch vụ vào hóa đơn
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
