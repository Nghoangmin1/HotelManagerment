@model IEnumerable<HotelManagement.Models.Room>
@using HotelManagement.Shared

@{
    ViewData["Title"] = "Quản lý danh sách phòng - HotelManagement";
}

<div class="hotel-mockup-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-success); padding: 16px 24px; color: var(--color-success); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-check" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="glass-panel flex-align-center" style="border-left: 4px solid var(--color-danger); padding: 16px 24px; color: var(--color-danger); font-weight: 600; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:12px; font-size:1.2rem;"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="glass-panel animate-fade" style="padding: 24px;">
        <div class="hotel-room-grid-header" style="margin-bottom: 24px;">
            <h3 style="font-size:1.2rem; font-weight:700;">
                <i class="fa-solid fa-hotel" style="color:var(--primary-color); margin-right:8px;"></i> Danh sách phòng hệ thống
            </h3>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Thêm phòng mới
            </a>
        </div>

        <div class="mock-table" style="background:#ffffff; box-shadow:none;">
            <div class="mock-table-header" style="grid-template-columns: 1fr 1.5fr 1fr 1.2fr 1.5fr 2fr; font-size: 0.85rem; padding: 12px 16px;">
                <div>Số phòng</div>
                <div>Loại phòng</div>
                <div>Đơn giá</div>
                <div>Trạng thái</div>
                <div>Khách lưu trú</div>
                <div style="text-align: right;">Thao tác</div>
            </div>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var statusLabel = RoomStatusHelper.GetStatusLabel(item.RoomStatus?.StatusCode ?? "");
                    var statusClass = RoomStatusHelper.GetStatusClass(item.RoomStatus?.StatusCode ?? "");

                    <div class="mock-table-row" style="grid-template-columns: 1fr 1.5fr 1fr 1.2fr 1.5fr 2fr; font-size: 0.85rem; padding: 16px 16px;">
                        <div style="font-weight: 800; color: var(--secondary-color);">P.@item.RoomNumber</div>
                        <div>@item.RoomType?.TypeName</div>
                        <div style="font-family:var(--font-mono)">@item.Price.ToString("N0")đ</div>
                        <div>
                            <span class="mock-status @statusClass" style="padding: 4px 10px; font-size:0.75rem;">
                                @statusLabel
                            </span>
                        </div>
                        <div style="font-weight: 500;">
                            @(string.IsNullOrEmpty(item.CustomerName) ? "-" : item.CustomerName)
                        </div>
                        <div style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline" style="padding: 6px 10px; font-size:0.75rem;">
                                <i class="fa-solid fa-eye"></i> Chi tiết
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline" style="padding: 6px 10px; font-size:0.75rem; border-color: var(--primary-color); color: var(--primary-color);">
                                <i class="fa-solid fa-pen-to-square"></i> Sửa
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng P.@item.RoomNumber khỏi hệ thống?')" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger" style="padding: 6px 10px; font-size:0.75rem;">
                                    <i class="fa-solid fa-trash-can"></i> Xóa
                                </button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center" style="padding: 48px; color: var(--text-muted);">
                    <i class="fa-solid fa-inbox" style="font-size: 3rem; margin-bottom: 12px; display:block;"></i>
                    Chưa có phòng nào được thiết lập trong hệ thống.
                </div>
            }
        </div>
    </div>
</div>
