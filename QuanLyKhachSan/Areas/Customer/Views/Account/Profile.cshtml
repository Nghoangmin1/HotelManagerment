@model HotelManagement.Areas.Customer.Models.CustomerProfileModel
@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Thông tin cá nhân - Grand Aura";
}

<div style="max-width: 800px; margin: 40px auto; padding: 0 24px;">
    <div style="background: #ffffff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; box-shadow: var(--shadow);">
        <div style="border-bottom: 1px solid var(--border); padding-bottom: 20px; margin-bottom: 24px; display: flex; align-items: center; gap: 16px;">
            <div style="width: 56px; height: 56px; background-color: rgba(37, 99, 235, 0.08); color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fa-solid fa-address-card"></i>
            </div>
            <div>
                <h1 style="font-size: 1.5rem; font-weight: 800; color: var(--dark);">Hồ Sơ Cá Nhân</h1>
                <p style="font-size: 0.85rem; color: #64748b; margin-top: 4px;">Xem và cập nhật thông tin liên hệ của bạn tại khách sạn</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background-color: rgba(22, 163, 74, 0.08); color: #16a34a; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
                <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div style="background-color: rgba(220, 38, 38, 0.08); color: #dc2626; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right: 8px;"></i> @TempData["ErrorMessage"]
            </div>
        }

        <form asp-area="Customer" asp-controller="Account" asp-action="Profile" method="post" style="display: flex; flex-direction: column; gap: 20px;">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 0.85rem; background-color: rgba(220, 38, 38, 0.08); padding: 10px; border-radius: 8px;"></div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                    <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Họ và tên khách hàng</label>
                    <input type="text" asp-for="FullName" class="form-input" placeholder="Nhập họ và tên..." required style="padding: 10px; border: 1px solid var(--border); border-radius: 8px; outline: none;" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>
                <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                    <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Địa chỉ Email</label>
                    <input type="email" asp-for="Email" class="form-input" placeholder="example@mail.com" required style="padding: 10px; border: 1px solid var(--border); border-radius: 8px; outline: none;" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                    <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Số điện thoại di động</label>
                    <input type="tel" asp-for="PhoneNumber" class="form-input" placeholder="0901234567" required style="padding: 10px; border: 1px solid var(--border); border-radius: 8px; outline: none;" />
                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>
                <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                    <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Số CMND / CCCD / Hộ chiếu</label>
                    <input type="text" asp-for="IdentityCard" class="form-input" placeholder="Số giấy tờ tùy thân..." required style="padding: 10px; border: 1px solid var(--border); border-radius: 8px; outline: none;" />
                    <span asp-validation-for="IdentityCard" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>
            </div>

            <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Địa chỉ thường trú</label>
                <input type="text" asp-for="Address" class="form-input" placeholder="Nhập địa chỉ nhà..." required style="padding: 10px; border: 1px solid var(--border); border-radius: 8px; outline: none;" />
                <span asp-validation-for="Address" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 10px; border-top: 1px solid var(--border); padding-top: 20px;">
                <a href="/" class="btn btn-outline" style="border-radius: 8px;">Quay lại</a>
                <button type="submit" class="btn btn-primary" style="border-radius: 8px;">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>
