@model IEnumerable<HotelManagement.Areas.Admin.Models.ServiceOrder>

@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Lịch sử dịch vụ đã đặt - Grand Aura";
}

<div style="max-width: 1000px; margin: 40px auto; padding: 0 24px 80px 24px;">
    <div style="background: #ffffff; border: 1px solid var(--border); border-radius: 16px; padding: 32px; box-shadow: var(--shadow);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 16px;">
            <h3 style="font-size:1.3rem; font-weight:800; color: var(--dark); margin:0;">
                <i class="fa-solid fa-clock-rotate-left" style="color:var(--primary); margin-right:8px;"></i> Lịch sử yêu cầu dịch vụ của bạn
            </h3>
            <a asp-action="Index" class="btn btn-primary" style="border-radius: 8px;">
                <i class="fa-solid fa-plus"></i> Đăng ký dịch vụ mới
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background-color: rgba(22, 163, 74, 0.08); color: #16a34a; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
                <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border); background-color: #f8fafc;">
                        <th style="padding: 12px; font-weight: 700; color: var(--dark);">Thời gian</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark);">Phòng ở</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark);">Tên dịch vụ</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark);">Đơn giá</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark); text-align: center;">Số lượng</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark); text-align: right;">Thành tiền</th>
                        <th style="padding: 12px; font-weight: 700; color: var(--dark); text-align: center;">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusColor = item.Status switch
                            {
                                "Pending" => "#f59e0b",
                                "Approved" => "#3b82f6",
                                "Completed" => "#10b981",
                                "Cancelled" => "#ef4444",
                                _ => "#64748b"
                            };

                            var statusLabel = item.Status switch
                            {
                                "Pending" => "Chờ duyệt",
                                "Approved" => "Đã duyệt",
                                "Completed" => "Đã phục vụ",
                                "Cancelled" => "Đã hủy",
                                _ => item.Status
                            };

                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: 16px 12px;">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="padding: 16px 12px; font-weight: 600;">P.@item.Booking?.Room?.RoomNumber</td>
                                <td style="padding: 16px 12px; font-weight: 600;">@item.Service?.ServiceName</td>
                                <td style="padding: 16px 12px; font-family: var(--font-mono);">@item.Service?.Price.ToString("N0")đ</td>
                                <td style="padding: 16px 12px; text-align: center;">@item.Quantity</td>
                                <td style="padding: 16px 12px; text-align: right; font-family: var(--font-mono); font-weight: 700; color: var(--primary);">
                                    @((item.Quantity * (item.Service?.Price ?? 0)).ToString("N0"))đ
                                </td>
                                <td style="padding: 16px 12px; text-align: center;">
                                    <span style="font-size: 0.75rem; font-weight: 700; padding: 4px 10px; border-radius: 20px; background-color: @(statusColor + "14"); color: @statusColor; border: 1px solid @(statusColor + "33")">
                                        @statusLabel
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 48px; color: #64748b;">
                                <i class="fa-solid fa-inbox" style="font-size: 2.5rem; color: #cbd5e1; margin-bottom: 12px; display:block;"></i>
                                Bạn chưa đăng ký dịch vụ nào trong các đợt lưu trú.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
