@model IEnumerable<HotelManagement.Areas.Admin.Models.Booking>
@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Lịch sử đặt phòng - Grand Aura";
}

<div style="max-width: 1000px; margin: 40px auto; padding: 0 24px;">
    <div style="background: #ffffff; border: 1px solid var(--border); border-radius: 12px; padding: 32px; box-shadow: var(--shadow); min-height: 450px;">
        <div style="border-bottom: 1px solid var(--border); padding-bottom: 20px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1 style="font-size: 1.5rem; font-weight: 800; color: var(--dark);">Lịch sử đặt phòng của bạn</h1>
                <p style="font-size: 0.85rem; color: #64748b; margin-top: 4px;">Xem danh sách và trạng thái các yêu cầu đặt phòng trực tuyến</p>
            </div>
            <a asp-action="RoomSearch" class="btn btn-primary" style="border-radius: 8px;">
                <i class="fa-solid fa-plus"></i> Đặt phòng mới
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background-color: rgba(22, 163, 74, 0.08); color: #16a34a; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
                <i class="fa-solid fa-circle-check" style="margin-right: 8px;"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem; color: var(--text-main);">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--border); padding-bottom: 12px; font-weight: 700; color: var(--dark);">
                            <th style="padding: 12px 8px;">Mã đặt phòng</th>
                            <th style="padding: 12px 8px;">Số phòng</th>
                            <th style="padding: 12px 8px;">Loại phòng</th>
                            <th style="padding: 12px 8px;">Nhận phòng</th>
                            <th style="padding: 12px 8px;">Trả phòng</th>
                            <th style="padding: 12px 8px;">Tổng chi phí</th>
                            <th style="padding: 12px 8px;">Trạng thái</th>
                            <th style="padding: 12px 8px; text-align: center;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            string badgeBg = "rgba(100, 116, 139, 0.08)";
                            string badgeColor = "#64748b";
                            string statusText = item.Status;

                            switch (item.Status)
                            {
                                case "Pending":
                                    badgeBg = "rgba(217, 119, 6, 0.08)";
                                    badgeColor = "#d97706";
                                    statusText = "Chờ duyệt";
                                    break;
                                case "Confirmed":
                                    badgeBg = "rgba(37, 99, 235, 0.08)";
                                    badgeColor = "#2563eb";
                                    statusText = "Đã xác nhận";
                                    break;
                                case "CheckedIn":
                                    badgeBg = "rgba(22, 163, 74, 0.08)";
                                    badgeColor = "#16a34a";
                                    statusText = "Đang ở";
                                    break;
                                case "CheckedOut":
                                    badgeBg = "rgba(100, 116, 139, 0.1)";
                                    badgeColor = "#64748b";
                                    statusText = "Đã trả phòng";
                                    break;
                                case "Cancelled":
                                    badgeBg = "rgba(220, 38, 38, 0.08)";
                                    badgeColor = "#dc2626";
                                    statusText = "Đã hủy";
                                    break;
                            }

                            <tr style="border-bottom: 1px solid var(--border); transition: background-color 0.15s ease;">
                                <td style="padding: 16px 8px; font-weight: 600;">#@item.Id</td>
                                <td style="padding: 16px 8px;">P.@item.Room?.RoomNumber</td>
                                <td style="padding: 16px 8px;">@item.Room?.RoomType?.TypeName</td>
                                <td style="padding: 16px 8px;">@item.CheckInDate.ToString("dd/MM/yyyy")</td>
                                <td style="padding: 16px 8px;">@(item.CheckOutDate?.ToString("dd/MM/yyyy") ?? "Chưa xác định")</td>
                                <td style="padding: 16px 8px; font-weight: 600; color: var(--primary);">@item.TotalPrice.ToString("N0")đ</td>
                                <td style="padding: 16px 8px;">
                                    <span style="font-size: 0.75rem; font-weight: 600; padding: 4px 10px; border-radius: 20px; background-color: @badgeBg; color: @badgeColor; display: inline-block;">
                                        @statusText
                                    </span>
                                </td>
                                <td style="padding: 16px 8px; text-align: center;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 0.8rem; border-radius: 6px;">
                                        <i class="fa-solid fa-circle-info"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 60px 20px;">
                <i class="fa-solid fa-calendar-xmark" style="font-size: 3.5rem; color: #cbd5e1; margin-bottom: 16px;"></i>
                <p style="color: #64748b; font-size: 0.95rem;">Bạn chưa có yêu cầu đặt phòng trực tuyến nào.</p>
                <a asp-action="RoomSearch" class="btn btn-primary" style="margin-top: 20px; border-radius: 8px;">
                    Tìm phòng & đặt ngay
                </a>
            </div>
        }
    </div>
</div>
