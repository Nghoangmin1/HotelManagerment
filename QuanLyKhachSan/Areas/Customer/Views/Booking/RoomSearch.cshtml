@model IEnumerable<dynamic>
@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Tìm phòng trống trực tuyến - Grand Aura";
}

<style>
    .search-banner {
        background: linear-gradient(rgba(15, 23, 42, 0.5), rgba(15, 23, 42, 0.75)), url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1200&q=80') no-repeat center center;
        background-size: cover;
        padding: 60px 24px;
        color: #ffffff;
        text-align: center;
        margin-bottom: 40px;
    }
    .room-search-card {
        background: #ffffff;
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        display: flex;
        margin-bottom: 24px;
        transition: transform 0.2s ease;
    }
    .room-search-card:hover {
        transform: translateY(-4px);
    }
    .room-img-section {
        width: 300px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 4rem;
        min-height: 200px;
    }
    .room-info-section {
        flex-grow: 1;
        padding: 24px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
</style>

<div class="search-banner">
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 12px;">Tìm phòng trống trực tuyến</h1>
    <p style="color: #cbd5e1; font-size: 1rem;">Chọn ngày để tìm kiếm các phòng nghỉ thích hợp nhất cho kỳ nghỉ của bạn</p>
</div>

<div style="max-width: 1100px; margin: 0 auto; padding: 0 24px 80px 24px;">
    <!-- Filter Panel -->
    <div style="background: #ffffff; border: 1px solid var(--border); border-radius: 12px; padding: 24px; box-shadow: var(--shadow); margin-bottom: 40px;">
        <form asp-area="Customer" asp-controller="Booking" asp-action="RoomSearch" method="get" style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 20px; align-items: flex-end;">
            <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Ngày nhận phòng</label>
                <input type="date" name="checkIn" value="@ViewBag.CheckIn" class="form-input" style="padding: 10px; border: 1px solid var(--border); border-radius: 8px;" required />
            </div>
            <div class="form-field" style="display: flex; flex-direction: column; gap: 6px;">
                <label class="field-label" style="font-size: 0.85rem; font-weight: 600; color: var(--dark);">Ngày trả phòng</label>
                <input type="date" name="checkOut" value="@ViewBag.CheckOut" class="form-input" style="padding: 10px; border: 1px solid var(--border); border-radius: 8px;" required />
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="height: 42px; padding: 0 24px; border-radius: 8px;">
                    <i class="fa-solid fa-magnifying-glass"></i> Kiểm tra phòng trống
                </button>
            </div>
        </form>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background-color: rgba(220, 38, 38, 0.08); color: #dc2626; padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px;">
            <i class="fa-solid fa-circle-exclamation" style="margin-right: 8px;"></i> @TempData["ErrorMessage"]
        </div>
    }

    <!-- Listings -->
    <div>
        <h2 style="font-size: 1.4rem; font-weight: 800; color: var(--dark); margin-bottom: 24px;">Kết quả tìm kiếm phòng</h2>
        
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                string iconClass = "fa-bed";
                if (item.TypeName.Contains("Đôi")) iconClass = "fa-hotel";
                else if (item.TypeName.Contains("Deluxe") || item.TypeName.Contains("VIP")) iconClass = "fa-crown";

                <div class="room-search-card">
                    <div class="room-img-section">
                        <i class="fa-solid @iconClass"></i>
                    </div>
                    <div class="room-info-section">
                        <div>
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                                <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--dark);">@item.TypeName</h3>
                                <span style="font-size: 0.8rem; font-weight: 600; padding: 4px 10px; border-radius: 20px; background-color: @(item.AvailableCount > 0 ? "rgba(22, 163, 74, 0.08)" : "rgba(220, 38, 38, 0.08)"); color: @(item.AvailableCount > 0 ? "#16a34a" : "#dc2626");">
                                    @(item.AvailableCount > 0 ? $"Còn trống {item.AvailableCount} phòng" : "Hết phòng")
                                </span>
                            </div>
                            <p style="color: #64748b; font-size: 0.9rem; line-height: 1.5; margin-bottom: 16px;">@item.Description</p>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border); padding-top: 16px;">
                            <div>
                                <span style="font-size: 0.8rem; color: #64748b; text-transform: uppercase; display: block; font-weight: 600;">Giá phòng</span>
                                <span style="font-size: 1.4rem; font-weight: 800; color: var(--primary);">@item.BasePrice.ToString("N0")đ <span style="font-size: 0.85rem; font-weight: 400; color: #64748b;">/ đêm</span></span>
                            </div>
                            <div>
                                @if (item.AvailableCount > 0)
                                {
                                    <a asp-area="Customer" asp-controller="Booking" asp-action="Create" asp-route-roomTypeId="@item.Id" asp-route-checkIn="@ViewBag.CheckIn" asp-route-checkOut="@ViewBag.CheckOut" class="btn btn-primary" style="border-radius: 8px;">
                                        <i class="fa-solid fa-calendar-check"></i> Đặt phòng ngay
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-outline" style="border-radius: 8px; cursor: not-allowed; color: #94a3b8; border-color: #cbd5e1;" disabled>
                                        Hết phòng trống
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; padding: 48px; border: 1px dashed var(--border); border-radius: 12px;">
                <i class="fa-solid fa-circle-question" style="font-size: 3rem; color: #cbd5e1; margin-bottom: 16px;"></i>
                <p style="color: #64748b;">Không tìm thấy thông tin loại phòng nào khả dụng.</p>
            </div>
        }
    </div>
</div>
