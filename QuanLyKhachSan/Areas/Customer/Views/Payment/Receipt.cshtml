@model HotelManagement.Areas.Admin.Models.Invoice

@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "Biên nhận thanh toán - Grand Aura";
    var booking = ViewBag.Booking as HotelManagement.Areas.Admin.Models.Booking;
}

<div style="max-width: 700px; margin: 40px auto; padding: 0 24px 80px 24px;">
    <div style="background: #ffffff; border: 1px solid var(--border); border-radius: 16px; padding: 40px; box-shadow: var(--shadow); text-align: center;">
        
        <div style="width: 72px; height: 72px; background: rgba(22, 163, 74, 0.1); color: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 20px auto;">
            <i class="fa-solid fa-circle-check"></i>
        </div>

        <h2 style="font-size: 1.6rem; font-weight: 800; color: var(--dark); margin-bottom: 8px;">Thanh toán thành công!</h2>
        <p style="color: #64748b; font-size: 0.95rem; margin-bottom: 32px;">Cảm ơn bạn đã lựa chọn lưu trú tại Grand Aura. Giao dịch của bạn đã được ghi nhận.</p>

        <!-- Receipt Card -->
        <div style="background: #f8fafc; border: 1px solid var(--border); border-radius: 12px; padding: 24px; text-align: left; font-size: 0.9rem; margin-bottom: 32px;">
            <h4 style="margin: 0 0 16px 0; font-size: 1rem; font-weight: 700; color: var(--dark); border-bottom: 1px solid var(--border); padding-bottom: 8px;">
                Chi tiết giao dịch
            </h4>
            
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Số hóa đơn:</span>
                    <span style="font-weight: 600; font-family: var(--font-mono);">@Model.InvoiceNumber</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Mã giao dịch:</span>
                    <span style="font-weight: 600; font-family: var(--font-mono);">@Model.Payment?.TransactionId</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Mã đặt phòng:</span>
                    <span style="font-weight: 600;">#@Model.BookingId</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Phòng ở:</span>
                    <span style="font-weight: 600;">P.@booking?.Room?.RoomNumber (@booking?.Room?.RoomType?.TypeName)</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Khách hàng:</span>
                    <span style="font-weight: 600;">@booking?.Customer?.FullName</span>
                </div>
                <div style="display: flex; justify-content: space-between; border-top: 1px dashed #e2e8f0; padding-top: 10px; margin-top: 4px;">
                    <span style="color: #64748b;">Phương thức:</span>
                    <span style="font-weight: 600;">Trực tuyến (Thẻ thanh toán)</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #64748b;">Ngày thanh toán:</span>
                    <span style="font-weight: 600;">@Model.Payment?.PaymentDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div style="display: flex; justify-content: space-between; border-top: 1px solid var(--border); padding-top: 10px; margin-top: 4px; font-size: 1.1rem; font-weight: 800;">
                    <span style="color: var(--dark);">Số tiền đã thanh toán:</span>
                    <span style="color: var(--primary); font-family: var(--font-mono);">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
            </div>
        </div>

        <div style="display: flex; gap: 12px; justify-content: center;">
            <a asp-controller="Booking" asp-action="History" class="btn btn-outline" style="border-radius: 8px;">
                <i class="fa-solid fa-list-check"></i> Xem phòng đã đặt
            </a>
            <a href="/" class="btn btn-primary" style="border-radius: 8px;">
                <i class="fa-solid fa-house"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>
